VITE_TMDB_ACCESS_TOKEN=your_tmdb_v4_read_access_token
VITE_TMDB_API_BASE_URL=https://api.themoviedb.org/3
VITE_TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p

# Set to "true" to enable Google AdSense. When false (or unset), the
# adsbygoogle script never loads and VITE_ADSENSE_CLIENT_ID/SLOT_ID are optional.
VITE_ADSENSE_ENABLED=false
VITE_ADSENSE_CLIENT_ID=ca-pub-xxxxxxxxxxxxxxxx
VITE_ADSENSE_SLOT_ID=xxxxxxxxxx
